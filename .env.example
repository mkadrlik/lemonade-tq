# lemonade-tq environment configuration
# Copy this file to .env and adjust values for your environment.
# See README.md for detailed setup instructions.

###############################################################################
# Docker image (optional - docker-compose.yml defaults to local build)
###############################################################################
LEMONADE_IMAGE=ghcr.io/mkadrlik/lemonade-tq:latest

###############################################################################
# Server
###############################################################################
# Host port mapping (container always listens on 13305)
LEMONADE_PORT=13306
LEMONADE_HOST=0.0.0.0

###############################################################################
# Backend selection
###############################################################################
# Backend: rocm (AMD), vulkan, or cpu
# Change this and the corresponding volume mount in docker-compose.yml
LEMONADE_LLAMACPP_BACKEND=rocm

###############################################################################
# TurboQuant image settings (for auto-fetching llama-server binaries)
###############################################################################
# Registry to pull llama-cpp-*-tq images from
TQ_REGISTRY=ghcr.io
# GitHub/org username
TQ_USER=mkadrlik
# Image tag
TQ_TAG=latest
# GitHub PAT with read:packages scope (required for private images)
# GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

###############################################################################
# ROCm-specific (AMD GPUs - remove for NVIDIA/CPU)
###############################################################################
# Override GPU architecture (adjust for your GPU)
# gfx1100 = RX 7900 series (RDNA3)
# gfx1030 = RX 6800/6900 series (RDNA2)
# gfx90a = MI200 series (CDNA2)
HSA_OVERRIDE_GFX_VERSION=11.0.0
# Comma-separated list of GPU indices to use
HIP_VISIBLE_DEVICES=0,1,2

###############################################################################
# TurboQuant + llama-server arguments
###############################################################################
# Split Mode Graph + TurboQuant KV cache compression
# -ngl 99 = offload all layers to GPU
# -ctk/-ctv = KV cache compression (turbo3 recommended)
# --tensor-split = VRAM split ratio across GPUs (1,1,1 = equal split across 3 GPUs)
# --batch-size = Size of chunks that are processed per pass
LEMONADE_LLAMACPP_ARGS=-fit off -sm layer -ngl 99 -ctk turbo3 -ctv turbo3 --tensor-split 1,1,1

###############################################################################
# Auto-load models on startup (space-separated, or leave empty)
###############################################################################
AUTO_LOAD_MODELS=Qwen3.6-27B-GGUF
